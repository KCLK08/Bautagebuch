{
  "expo": {
    "name": "Bautagebuch",
    "slug": "bautagebuch",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bautagebuch",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buew.bautagebuch",
      "infoPlist": {
        "NSCameraUsageDescription": "Die Kamera wird für die Fotodokumentation auf der Baustelle benötigt.",
        "NSPhotoLibraryUsageDescription": "Die Galerie wird für die Fotodokumentation benötigt.",
        "NSLocationWhenInUseUsageDescription": "Der Standort wird verwendet, um Wetterdaten automatisch zu laden."
      }
    },
    "android": {
      "package": "com.buew.bautagebuch",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#12534b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#12534b"
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Die App benötigt Zugriff auf Fotos für die Fotodokumentation.",
          "cameraPermission": "Die App benötigt die Kamera für die Fotodokumentation."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Der Standort wird für automatische Wetterdaten verwendet."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
